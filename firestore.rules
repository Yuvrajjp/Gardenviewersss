rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only shared layout
    match /garden/layout {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Per-bed assignments: public read, signed-in edit
    match /garden_allocations/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
